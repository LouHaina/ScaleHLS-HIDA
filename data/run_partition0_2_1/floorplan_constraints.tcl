proc get_func_cells {funcName} {
    set cells [list]

    # Pattern 1: typical HLS instance, e.g. grp_forward_node82_fu_..._U0
    set pat1 "*${funcName}*_U0"
    set c [get_cells -hier -quiet -filter "NAME =~ $pat1"]

    # If nothing, try a looser pattern
    if {[llength $c] == 0} {
        set pat2 "*${funcName}*"
        set c [get_cells -hier -quiet -filter "NAME =~ $pat2"]
        puts "get_func_cells: $funcName -> [llength $c] cells (fallback pattern: $pat2)"
    } else {
        puts "get_func_cells: $funcName -> [llength $c] cells (pattern: $pat1)"
    }

    # Safely accumulate (no {*} expansion)
    foreach cell $c {
        lappend cells $cell
    }

    return [lsort -unique $cells]
}

